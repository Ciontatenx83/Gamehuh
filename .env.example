# Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file with real keys to version control

# ===== STRIPE CONFIGURATION =====
STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ===== PAYPAL CONFIGURATION =====
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_SECRET=YOUR_PAYPAL_SECRET_HERE
PAYPAL_MODE=sandbox

# ===== DATABASE CONFIGURATION =====
DB_HOST=localhost
DB_PORT=27017
DB_NAME=gamehub
DB_USERNAME=admin
DB_PASSWORD=your_password_here

# ===== EMAIL CONFIGURATION =====
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE
EMAIL_FROM=noreply@gamehub.com
EMAIL_FROM_NAME=GameHub

# ===== AWS CONFIGURATION =====
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_REGION=us-east-1
AWS_S3_BUCKET=gamehub-downloads

# ===== APPLICATION CONFIGURATION =====
NODE_ENV=development
PORT=3000
HOST=localhost

# ===== SESSION =====
SESSION_SECRET=your_session_secret_here_generate_random_string

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ===== TAX & PRICING =====
TAX_RATE=0.08
CURRENCY=USD

# ===== FEATURES =====
ENABLE_CRYPTO_PAYMENTS=false
ENABLE_AFFILIATE_PROGRAM=true
ENABLE_REFERRAL_SYSTEM=true
